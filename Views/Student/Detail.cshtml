@model GathalaMFS.Models.StudentDetail

@{
    ViewBag.Title = "Student Details";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Details</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
            :root {
                --bg: #f0f2f8;
                --card: #ffffff;
                --primary: #2563eb;
                --primary-hover: #1d4ed8;
                --primary-light: #eff6ff;
                --accent: #0ea5e9;
                --text-head: #0f172a;
                --text-body: #334155;
                --text-muted: #94a3b8;
                --border: #e2e8f0;
                --radius: 18px;
                --radius-sm: 10px;
            }

            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                background: var(--bg);
                font-family: 'DM Sans', sans-serif;
                color: var(--text-body);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 24px;
            }

            /* ── Overlay backdrop ── */
            .sd-overlay {
                position: fixed;
                inset: 0;
                background: rgba(15, 23, 42, 0.45);
                backdrop-filter: blur(6px);
                -webkit-backdrop-filter: blur(6px);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
                z-index: 999;
                animation: fadeIn .25s ease;
            }

            @@keyframes fadeIn {
                from {
                    opacity: 0;
                }

                to {
                    opacity: 1;
                }
            }

            /* ── Modal card ── */
            .sd-modal {
                background: var(--card);
                border-radius: var(--radius);
                width: 100%;
                max-width: 520px;
                box-shadow: 0 24px 64px rgba(15,23,42,0.18), 0 4px 16px rgba(15,23,42,0.08);
                overflow: hidden;
                animation: slideUp .3s cubic-bezier(.34,1.26,.64,1) both;
            }

            @@keyframes slideUp {
                from {
                    opacity: 0;
                    transform: translateY(28px) scale(.97);
                }

                to {
                    opacity: 1;
                    transform: translateY(0) scale(1);
                }
            }

            /* ── Modal header ── */
            .sd-header {
                background: linear-gradient(135deg, var(--primary) 0%, #1e40af 100%);
                /* padding: 28px 30px 24px; */
                position: relative;
                display: flex;
                align-items: flex-start;
                gap: 16px;
            }

            .sd-header-icon {
                width: 50px;
                height: 50px;
                background: rgba(255,255,255,0.18);
                border-radius: 13px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
                border: 1.5px solid rgba(255,255,255,0.25);
            }

                .sd-header-icon i {
                    color: #fff;
                    font-size: 1.25rem;
                }

            .sd-header-text {
                flex: 1;
            }

            .sd-label {
                font-family: 'DM Sans', sans-serif;
                font-size: 0.68rem;
                font-weight: 600;
                letter-spacing: 0.10em;
                text-transform: uppercase;
                color: rgba(255,255,255,0.65);
                margin-bottom: 4px;
            }

            .sd-title {
                font-size: 1.35rem;
                font-weight: 800;
                color: #fff;
                letter-spacing: -0.01em;
                line-height: 1.2;
            }

            .sd-subtitle {
                font-size: 0.80rem;
                color: rgba(255,255,255,0.60);
                margin-top: 3px;
            }

            /* close × */
            .sd-close {
                position: absolute;
                top: 18px;
                right: 18px;
                width: 32px;
                height: 32px;
                background: rgba(255,255,255,0.14);
                border: 1px solid rgba(255,255,255,0.22);
                border-radius: 8px;
                color: #fff;
                font-size: 0.85rem;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: background .18s, transform .15s;
                text-decoration: none;
            }

                .sd-close:hover {
                    background: rgba(255,255,255,0.28);
                    transform: scale(1.08);
                }

            /* decorative dots */
            .sd-header::after {
                content: '';
                position: absolute;
                right: -30px;
                top: -30px;
                width: 140px;
                height: 140px;
                border-radius: 50%;
                background: rgba(255,255,255,0.06);
                pointer-events: none;
            }

            .sd-header::before {
                content: '';
                position: absolute;
                right: 40px;
                bottom: -40px;
                width: 90px;
                height: 90px;
                border-radius: 50%;
                background: rgba(255,255,255,0.05);
                pointer-events: none;
            }

            /* ── Body ── */
            .sd-body {
                padding: 24px 30px 10px;
            }

            /* ── Row ── */
            .sd-row {
                display: flex;
                align-items: flex-start;
                gap: 14px;
                padding: 14px 0;
                border-bottom: 1px solid var(--border);
                animation: rowIn .4s ease both;
            }

                .sd-row:last-child {
                    border-bottom: none;
                }

            @@keyframes rowIn {
                from {
                    opacity: 0;
                    transform: translateX(-8px);
                }

                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            .sd-row:nth-child(1) {
                animation-delay: .05s;
            }

            .sd-row:nth-child(2) {
                animation-delay: .10s;
            }

            .sd-row:nth-child(3) {
                animation-delay: .15s;
            }

            .sd-row:nth-child(4) {
                animation-delay: .20s;
            }

            .sd-row:nth-child(5) {
                animation-delay: .25s;
            }

            .sd-icon-wrap {
                width: 36px;
                height: 36px;
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
                margin-top: 1px;
            }

                .sd-icon-wrap i {
                    font-size: 0.85rem;
                }

            /* colour variants */
            .ico-blue {
                background: #eff6ff;
            }

                .ico-blue i {
                    color: #2563eb;
                }

            .ico-indigo {
                background: #eef2ff;
            }

                .ico-indigo i {
                    color: #4f46e5;
                }

            .ico-green {
                background: #f0fdf4;
            }

                .ico-green i {
                    color: #16a34a;
                }

            .ico-orange {
                background: #fff7ed;
            }

                .ico-orange i {
                    color: #ea580c;
                }

            .ico-sky {
                background: #f0f9ff;
            }

                .ico-sky i {
                    color: #0284c7;
                }

            .sd-field {
                flex: 1;
                min-width: 0;
            }

            .sd-field-label {
                font-size: 0.68rem;
                font-weight: 700;
                letter-spacing: 0.09em;
                text-transform: uppercase;
                color: var(--text-muted);
                margin-bottom: 3px;
            }

            .sd-field-value {
                font-size: 0.93rem;
                font-weight: 600;
                color: var(--text-head);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            /* special badges */
            .sd-badge-course {
                display: inline-block;
                padding: 3px 12px;
                border-radius: 20px;
                font-size: 0.82rem;
                font-weight: 700;
                background: #f0fdf4;
                color: #16a34a;
                border: 1px solid #bbf7d0;
            }

            .sd-badge-duration {
                display: inline-flex;
                align-items: center;
                gap: 5px;
                padding: 3px 12px;
                background: #fff7ed;
                color: #ea580c;
                border-radius: 20px;
                font-size: 0.82rem;
                font-weight: 700;
                border: 1px solid #fed7aa;
            }

            /* ── Footer ── */
            .sd-footer {
                padding: 18px 30px 26px;
                display: flex;
                align-items: center;
                justify-content: flex-end;
                gap: 10px;
                border-top: 1px solid var(--border);
                margin-top: 6px;
            }

            .sd-btn-ghost {
                display: inline-flex;
                align-items: center;
                gap: 7px;
                padding: 9px 20px;
                border: 1.5px solid var(--border);
                border-radius: var(--radius-sm);
                background: #fff;
                color: var(--text-body);
                font-family: 'DM Sans', sans-serif;
                font-size: 0.85rem;
                font-weight: 600;
                text-decoration: none;
                cursor: pointer;
                transition: border-color .2s, background .2s, transform .15s;
            }

                .sd-btn-ghost:hover {
                    border-color: var(--primary);
                    color: var(--primary);
                    background: var(--primary-light);
                    transform: translateY(-1px);
                }

            .sd-btn-primary {
                display: inline-flex;
                align-items: center;
                gap: 7px;
                padding: 9px 22px;
                background: var(--primary);
                color: #fff;
                font-family: 'DM Sans', sans-serif;
                font-size: 0.85rem;
                font-weight: 600;
                border: none;
                border-radius: var(--radius-sm);
                cursor: pointer;
                text-decoration: none;
                transition: background .2s, transform .15s, box-shadow .2s;
                box-shadow: 0 2px 10px rgba(37,99,235,0.28);
            }

                .sd-btn-primary:hover {
                    background: var(--primary-hover);
                    transform: translateY(-1px);
                    box-shadow: 0 6px 18px rgba(37,99,235,0.34);
                    color: #fff;
                }

                .sd-btn-primary:active,
                .sd-btn-ghost:active {
                    transform: translateY(0);
                }

            /* ── Mobile ── */
            @@media (max-width: 480px) {
                .sd-modal {
                    border-radius: 14px;
                }

                /* .sd-header {
                    padding: 22px 20px 18px;
                } */

                .sd-body {
                    padding: 18px 20px 6px;
                }

                .sd-footer {
                    padding: 14px 20px 20px;
                }

                .sd-title {
                    font-size: 1.15rem;
                }
            }
            img{
                height: 120px;
                width: 520px;
            }
    </style>
</head>
<body>

    <div class="sd-overlay" id="sdOverlay">
        <div class="sd-modal" role="dialog" aria-modal="true" aria-labelledby="sdTitle">

            <!-- Header -->
            <div class="sd-header">
                @* <div class="sd-header-icon">
                    <i class="fa-solid fa-user-graduate"></i>
                </div>
                <div class="sd-header-text">
                    <p class="sd-label">Student Profile</p>
                    <h2 class="sd-title" id="sdTitle">@Model.CandidateName</h2>
                    <p class="sd-subtitle">@Model.InstituteName</p>
                </div>
                <a href="javascript:history.back()" class="sd-close" title="Close">
                    <i class="fa-solid fa-xmark"></i>
                </a> *@
                <img src="~/image/image1.png" />
            </div>

            <!-- Body -->
            <div class="sd-body">

                <div class="sd-row">
                    <div class="sd-icon-wrap ico-blue">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <div class="sd-field">
                        <p class="sd-field-label">Candidate Name</p>
                        <p class="sd-field-value">@Model.CandidateName</p>
                    </div>
                </div>

                <div class="sd-row">
                    <div class="sd-icon-wrap ico-indigo">
                        <i class="fa-solid fa-person"></i>
                    </div>
                    <div class="sd-field">
                        <p class="sd-field-label">Father Name</p>
                        <p class="sd-field-value">@Model.FatherName</p>
                    </div>
                </div>

                <div class="sd-row">
                    <div class="sd-icon-wrap ico-green">
                        <i class="fa-solid fa-book-open"></i>
                    </div>
                    <div class="sd-field">
                        <p class="sd-field-label">Course Name</p>
                        <p class="sd-field-value">
                            <span class="sd-badge-course">@Model.CourseName</span>
                        </p>
                    </div>
                </div>

                <div class="sd-row">
                    <div class="sd-icon-wrap ico-orange">
                        <i class="fa-regular fa-clock"></i>
                    </div>
                    <div class="sd-field">
                        <p class="sd-field-label">Duration</p>
                        <p class="sd-field-value">
                            <span class="sd-badge-duration">
                                <i class="fa-solid fa-hourglass-half"></i>
                                @Model.Duration
                            </span>
                        </p>
                    </div>
                </div>

                <div class="sd-row">
                    <div class="sd-icon-wrap ico-sky">
                        <i class="fa-solid fa-building-columns"></i>
                    </div>
                    <div class="sd-field">
                        <p class="sd-field-label">Institute Name</p>
                        <p class="sd-field-value">@Model.InstituteName</p>
                    </div>
                </div>

            </div><!-- /sd-body -->
            <!-- Footer -->
            @* <div class="sd-footer">
                <a href="javascript:history.back()" class="sd-btn-ghost">
                    <i class="fa-solid fa-arrow-left"></i> Back
                </a>
                <button class="sd-btn-primary" onclick="window.print()">
                    <i class="fa-solid fa-print"></i> Print
                </button>
            </div> *@

        </div><!-- /sd-modal -->
    </div><!-- /sd-overlay -->

</body>
</html>
