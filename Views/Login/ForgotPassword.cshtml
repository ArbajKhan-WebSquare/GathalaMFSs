@model GathalaMFS.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Reset Password | GathalaMFS</title>
    <!-- Google Fonts: Inter for modern sans-serif -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <!-- Font Awesome 6 (free icons) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f2b3d 0%, #1b4f6e 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            position: relative;
        }

        /* decorative background elements */
        body::before {
            content: "";
            position: absolute;
            width: 280px;
            height: 280px;
            background: rgba(255,255,240,0.06);
            border-radius: 50%;
            top: -80px;
            left: -60px;
            z-index: 0;
        }
        body::after {
            content: "";
            position: absolute;
            width: 380px;
            height: 380px;
            background: rgba(255,215,150,0.04);
            border-radius: 50%;
            bottom: -130px;
            right: -90px;
            z-index: 0;
        }

        /* main card container */
        .reset-container {
            width: 100%;
            max-width: 520px;
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(2px);
            border-radius: 2rem;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.35), 0 1px 2px rgba(0,0,0,0.05);
            overflow: hidden;
            transition: transform 0.2s ease;
            z-index: 2;
        }

        .reset-container:hover {
            transform: translateY(-4px);
        }

        /* header area with security branding */
        .reset-header {
            background: #1e3a4d;
            /* padding: 1.8rem 2rem 1.5rem; */
            text-align: center;
            color: white;
        }

        .brand-icon {
            background: #ffb347;
            width: 70px;
            height: 70px;
            line-height: 70px;
            text-align: center;
            border-radius: 35px;
            margin: 0 auto 1rem;
            box-shadow: 0 8px 14px rgba(0,0,0,0.2);
        }

        .brand-icon i {
            color: #1e2f3a;
            font-size: 2.4rem;
            vertical-align: middle;
        }

        .reset-header h2 {
            font-weight: 700;
            font-size: 1.8rem;
            letter-spacing: -0.3px;
            margin-bottom: 0.25rem;
        }

        .reset-header p {
            font-size: 0.85rem;
            opacity: 0.85;
            font-weight: 400;
        }

        /* form content */
        .reset-form {
            padding: 2rem 2rem 2.2rem;
        }

        /* modern input groups */
        .input-group-custom {
            margin-bottom: 1.6rem;
            position: relative;
        }

        .input-group-custom label {
            display: block;
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
            color: #1f3e48;
            letter-spacing: -0.2px;
        }

        .input-group-custom label i {
            margin-right: 8px;
            font-size: 0.9rem;
            color: #ff8c42;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-wrapper input {
            width: 100%;
            padding: 0.85rem 1rem;
            font-size: 1rem;
            border: 1.5px solid #e2e8f0;
            border-radius: 1.2rem;
            background-color: #fefefe;
            transition: all 0.2s ease;
            font-family: 'Inter', monospace;
            font-weight: 500;
            outline: none;
            color: #1a2c36;
        }

        .input-wrapper input:focus {
            border-color: #ff9f4a;
            box-shadow: 0 0 0 4px rgba(255, 159, 74, 0.2);
            background-color: #ffffff;
        }

        .input-wrapper input::placeholder {
            color: #b9c8d4;
            font-weight: 400;
            font-size: 0.9rem;
        }

        /* toggle password button */
        .toggle-pwd {
            position: absolute;
            right: 16px;
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 1.1rem;
            color: #7f8c8d;
            transition: color 0.2s;
        }
        .toggle-pwd:hover {
            color: #ff8c42;
        }

        /* password strength indicator (nice UX addition) */
        .password-strength {
            margin-top: 8px;
            font-size: 0.7rem;
            display: flex;
            align-items: center;
            gap: 6px;
            color: #6c868e;
        }

        .strength-bar {
            height: 4px;
            flex: 1;
            background: #e2e8f0;
            border-radius: 4px;
            overflow: hidden;
        }

        .strength-fill {
            width: 0%;
            height: 100%;
            background: #ff9142;
            border-radius: 4px;
            transition: width 0.2s;
        }

        /* reset button */
        .reset-btn {
            width: 100%;
            background: linear-gradient(105deg, #ff9142 0%, #ff6a2e 100%);
            border: none;
            padding: 0.9rem;
            font-size: 1.05rem;
            font-weight: 700;
            color: white;
            border-radius: 2rem;
            cursor: pointer;
            transition: all 0.25s;
            box-shadow: 0 6px 14px rgba(255, 107, 46, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            letter-spacing: 0.3px;
            margin-top: 0.5rem;
        }

        .reset-btn i {
            font-size: 1.1rem;
        }

        .reset-btn:hover {
            background: linear-gradient(105deg, #ff7a2c 0%, #ff551a 100%);
            transform: scale(1.01);
            box-shadow: 0 12px 22px rgba(255, 80, 30, 0.4);
        }

        /* message containers */
        .error-message {
            background: #ffe9e6;
            border-left: 5px solid #e34d3a;
            padding: 0.8rem 1rem;
            border-radius: 1rem;
            margin-top: 1.2rem;
            font-size: 0.85rem;
            font-weight: 500;
            color: #bc3900;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .success-message {
            background: #e0f7e8;
            border-left: 5px solid #2e9c5f;
            padding: 0.8rem 1rem;
            border-radius: 1rem;
            margin-top: 1rem;
            font-size: 0.85rem;
            font-weight: 500;
            color: #1f6e43;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .error-message i, .success-message i {
            font-size: 1.1rem;
        }

        /* back to login link */
        .back-link {
            text-align: center;
            margin-top: 1.6rem;
            border-top: 1px solid #eef2f5;
            padding-top: 1.2rem;
        }

        .back-link a {
            color: #2c6e9e;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
            transition: color 0.2s;
        }

        .back-link a i {
            font-size: 0.8rem;
        }

        .back-link a:hover {
            color: #ff7b2c;
            text-decoration: underline;
        }

        /* inline validation hint */
        .field-hint {
            font-size: 0.7rem;
            color: #7c9aa8;
            margin-top: 5px;
            margin-left: 10px;
        }

        /* responsive adjustments */
        @@media (max-width: 560px) {
            .reset-container {
                max-width: 100%;
            }
            .reset-form {
                padding: 1.5rem;
            }
            /* .reset-header {
                padding: 1.4rem 1rem;
            } */
        }

        img {
            height: 150px;
            width: stretch;
        }
    </style>
</head>
<body>
    <div class="reset-container">
        <div class="reset-header">
            @* <div class="brand-icon">
                <i class="fas fa-key"></i>
            </div>
            <h2>Reset Password</h2>
            <p>Create a new secure password for your account</p> *@
            <img src="~/image/image1.png" />
        </div>

        <div class="reset-form">
            <!-- 
                This form fully preserves the original ASP.NET Core model binding.
                Model: GathalaMFS.Models.ForgotPasswordViewModel
                Properties: Username, NewPassword, ConfirmPassword
                Method="post" works with your backend ResetPassword action.
                ViewBag.Error and ViewBag.Success are displayed dynamically.
                Layout = null is respected.
            -->
            <form method="post" id="resetForm" novalidate>
                <!-- Username field -->
                <div class="input-group-custom">
                    <label for="Username">
                        <i class="fas fa-user-circle"></i> Username
                    </label>
                    <div class="input-wrapper">
                        <input asp-for="Username" class="form-control" id="Username" 
                               placeholder="Enter your registered username" 
                               autocomplete="username" />
                    </div>
                    <div class="field-hint">
                        <i class="fas fa-info-circle"></i> We'll verify your identity
                    </div>
                </div>

                <!-- New Password field with toggle and strength meter -->
                <div class="input-group-custom">
                    <label for="NewPassword">
                        <i class="fas fa-lock"></i> New Password
                    </label>
                    <div class="input-wrapper">
                        <input asp-for="NewPassword" type="password" class="form-control" id="NewPassword"
                               placeholder="Create a strong password" autocomplete="new-password" />
                        <button type="button" class="toggle-pwd" data-target="NewPassword" aria-label="Show password">
                            <i class="far fa-eye-slash"></i>
                        </button>
                    </div>
                    <!-- password strength visual (client side, just helpful UX) -->
                    <div class="password-strength" id="strengthIndicator">
                        <span><i class="fas fa-shield-alt"></i> Password strength:</span>
                        <div class="strength-bar">
                            <div class="strength-fill" id="strengthFill"></div>
                        </div>
                        <span id="strengthText" style="font-size:0.7rem; font-weight:500;">None</span>
                    </div>
                </div>

                <!-- Confirm Password field with toggle -->
                <div class="input-group-custom">
                    <label for="ConfirmPassword">
                        <i class="fas fa-check-circle"></i> Confirm Password
                    </label>
                    <div class="input-wrapper">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" id="ConfirmPassword"
                               placeholder="Re-enter your new password" autocomplete="new-password" />
                        <button type="button" class="toggle-pwd" data-target="ConfirmPassword" aria-label="Show password">
                            <i class="far fa-eye-slash"></i>
                        </button>
                    </div>
                    <div class="field-hint" id="confirmMatchHint">
                        <i class="fas fa-redo-alt"></i> Must match the new password
                    </div>
                </div>

                <!-- Reset button -->
                <button type="submit" class="reset-btn">
                    <i class="fas fa-sync-alt"></i> Reset Password
                </button>

                <!-- Server-side message areas (original ViewBag.Error & ViewBag.Success) -->
                @if (!string.IsNullOrEmpty(ViewBag.Error))
                {
                    <div class="error-message">
                        <i class="fas fa-circle-exclamation"></i>
                        <span>@ViewBag.Error</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(ViewBag.Success))
                {
                    <div class="success-message">
                        <i class="fas fa-check-circle"></i>
                        <span>@ViewBag.Success</span>
                    </div>
                }

                <!-- Back to Login link (helpful navigation) -->
                <div class="back-link">
                    <a asp-controller="Login" asp-action="Index">
                        <i class="fas fa-arrow-left"></i> Back to Login
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script>
        (function() {
            // ========== PASSWORD TOGGLE (both fields) ==========
            const toggleButtons = document.querySelectorAll('.toggle-pwd');
            toggleButtons.forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const targetId = this.getAttribute('data-target');
                    const inputField = document.getElementById(targetId);
                    if (inputField) {
                        const type = inputField.getAttribute('type') === 'password' ? 'text' : 'password';
                        inputField.setAttribute('type', type);
                        const icon = this.querySelector('i');
                        if (icon) {
                            if (type === 'text') {
                                icon.classList.remove('fa-eye-slash');
                                icon.classList.add('fa-eye');
                            } else {
                                icon.classList.remove('fa-eye');
                                icon.classList.add('fa-eye-slash');
                            }
                        }
                    }
                });
            });

            // ========== PASSWORD STRENGTH METER (for NewPassword) ==========
            const newPwdInput = document.getElementById('NewPassword');
            const strengthFill = document.getElementById('strengthFill');
            const strengthTextSpan = document.getElementById('strengthText');

            function calculateStrength(password) {
                if (!password) return 0;
                let score = 0;
                if (password.length >= 8) score += 1;
                if (password.length >= 12) score += 1;
                if (/[A-Z]/.test(password)) score += 1;
                if (/[0-9]/.test(password)) score += 1;
                if (/[^A-Za-z0-9]/.test(password)) score += 1;
                return Math.min(score, 4);
            }

            function updateStrengthMeter() {
                const pwd = newPwdInput.value;
                const strength = calculateStrength(pwd);
                let percent = 0;
                let text = '';
                if (strength === 0) { percent = 0; text = 'Very Weak'; }
                else if (strength === 1) { percent = 25; text = 'Weak'; }
                else if (strength === 2) { percent = 50; text = 'Fair'; }
                else if (strength === 3) { percent = 75; text = 'Good'; }
                else { percent = 100; text = 'Strong'; }
                
                if (strengthFill) {
                    strengthFill.style.width = percent + '%';
                    if (strength >= 3) {
                        strengthFill.style.background = '#2e9c5f';
                    } else if (strength === 2) {
                        strengthFill.style.background = '#ffb347';
                    } else {
                        strengthFill.style.background = '#e34d3a';
                    }
                }
                if (strengthTextSpan) strengthTextSpan.innerText = text;
            }

            if (newPwdInput) {
                newPwdInput.addEventListener('input', updateStrengthMeter);
                updateStrengthMeter(); // initial
            }

            // ========== REAL-TIME CONFIRM PASSWORD MATCH VISUAL FEEDBACK ==========
            const confirmInput = document.getElementById('ConfirmPassword');
            const matchHint = document.getElementById('confirmMatchHint');

            function validateConfirmMatch() {
                const newPwd = newPwdInput ? newPwdInput.value : '';
                const confirmVal = confirmInput ? confirmInput.value : '';
                if (confirmVal.length === 0) {
                    if (matchHint) {
                        matchHint.innerHTML = '<i class="fas fa-redo-alt"></i> Must match the new password';
                        matchHint.style.color = '#7c9aa8';
                    }
                    return;
                }
                if (newPwd === confirmVal) {
                    if (matchHint) {
                        matchHint.innerHTML = '<i class="fas fa-check-circle"></i> Passwords match';
                        matchHint.style.color = '#2e9c5f';
                    }
                } else {
                    if (matchHint) {
                        matchHint.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Passwords do not match';
                        matchHint.style.color = '#e34d3a';
                    }
                }
            }

            if (confirmInput && newPwdInput) {
                confirmInput.addEventListener('input', validateConfirmMatch);
                newPwdInput.addEventListener('input', validateConfirmMatch);
            }

            // ========== OPTIONAL: simple client side validation before submit to improve UX ==========
            const form = document.getElementById('resetForm');
            if (form) {
                form.addEventListener('submit', function(e) {
                    const username = document.getElementById('Username')?.value.trim();
                    const newPwd = newPwdInput?.value;
                    const confirmPwd = confirmInput?.value;
                    
                    // Only provide friendly hints; server-side validation remains authoritative.
                    // But we avoid blocking actual post because model validation will handle.
                    if (!username) {
                        // We do not prevent submission but show a stylistic hint? 
                        // To keep consistent with backend-first, we let server respond.
                        // However, we add a small UX warning but not prevent full post.
                        const usernameGroup = document.getElementById('Username')?.closest('.input-group-custom');
                        if (usernameGroup && !document.getElementById('clientUsernameWarn')) {
                            const warnSpan = document.createElement('div');
                            warnSpan.id = 'clientUsernameWarn';
                            warnSpan.className = 'field-hint';
                            warnSpan.style.color = '#e34d3a';
                            warnSpan.innerHTML = '<i class="fas fa-info-circle"></i> Username is required';
                            usernameGroup.appendChild(warnSpan);
                            setTimeout(() => warnSpan.remove(), 2500);
                        }
                    }
                    
                    if (newPwd && confirmPwd && newPwd !== confirmPwd) {
                        // Just show an extra message but allow server to return error too
                        if (matchHint) {
                            matchHint.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Passwords do not match — please correct';
                            matchHint.style.color = '#e34d3a';
                        }
                        // We don't prevent because backend will catch, but avoid blocking
                    }
                    // allow full post for modelstate handling
                });
            }
            
            
        })();
    </script>

   
</body>
</html>